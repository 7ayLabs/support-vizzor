# ─────────────────────────────────────────────────────────────
# support-vizzor — minimum environment
# ─────────────────────────────────────────────────────────────

# Public origin of the site (used in canonical URLs, CSP, etc.)
NEXT_PUBLIC_SUPPORT_ORIGIN=https://support.vizzor.ai

# Cross-origin SSO target — support-vizzor proxies wallet-identity
# lookups through this base. Must serve /api/auth/handoff and
# /api/auth/session (see docs/ops/sso-handoff.md for the contract).
NEXT_PUBLIC_VIZZOR_ORIGIN=https://vizzor.ai

# HMAC salt for IP-bucket rate-limiting. Same pattern as site-vizzor's
# VIZZOR_RATE_LIMIT_SALT — required in prod, falls back to a dev value
# in non-prod so localhost still rate-limits coherently.
SUPPORT_RATE_LIMIT_SALT=change-me-in-prod

# Public ticket-id seed (HMAC keyed) so ticket short-codes don't leak
# row IDs. Same rotation rules as the rate-limit salt.
SUPPORT_TICKET_ID_SALT=change-me-in-prod

# Outbound triage webhook — optional. If set, every new ticket POSTs
# a sanitized payload here (n8n, Slack, Linear bridge, etc.) for ops
# notification. The DB is the source of truth either way.
SUPPORT_TRIAGE_WEBHOOK_URL=

# JWT secret shared with site-vizzor for SSO handoff verification.
# Generated once with `openssl rand -hex 32`. Same value must be set
# in site-vizzor's env so HS256 signatures roundtrip.
SUPPORT_SSO_JWT_SECRET=

# Reverse-proxy trust list — only honor X-Forwarded-For from this
# comma-separated allowlist. nginx on the VPS is the only proxy in
# front of this container.
SUPPORT_TRUSTED_PROXIES=127.0.0.1,::1
